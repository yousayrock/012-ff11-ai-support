ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════
#  キャラクターカスタマイズ（省略するとデフォルトのミアになります）
# ═══════════════════════════════════════════════

# キャラクター名
# CHAR_NAME=ミア

# キャラクタープロフィール（種族・経歴・性格など）
# CHAR_PROFILE=ミスラ族の冒険者。FF11を20年以上プレイした先輩プレイヤーAI。明るく好奇心旺盛。

# 口調・話し方
# CHAR_TONE=明るくフレンドリー。「〜だよ！」「〜ね！」「いっしょに冒険しよ〜！」が口ぐせ。

# 口調例（AIへの参考文。\n で複数行）
# CHAR_TONE_EXAMPLES=「サラマンダーのWSはインファーノだよ！前衛は必ず散開してね！」

# ═══════════════════════════════════════════════
#  検索
# ═══════════════════════════════════════════════

# Brave Search API（無料 2000回/月）
# https://api.search.brave.com/ で取得
BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════
#  音声合成（AivisSpeech / VOICEVOX互換）
# ═══════════════════════════════════════════════

# 起動後 http://localhost:10101/speakers でスピーカーID確認
TTS_URL=http://localhost:10101
TTS_SPEAKER=888753760
TTS_SPEED=1.1
TTS_PITCH=0.05
TTS_INTONATION=1.2

# Docker Compose でコンテナ同士の場合はサービス名に変更
# TTS_URL=http://aivisspeech:10101
